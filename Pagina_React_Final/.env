# ============================================================
# ViceLeteChile — Variables de entorno para EmailJS
# ============================================================
# INSTRUCCIONES:
#   1. Copia este archivo y renómbralo a ".env" (sin el .example)
#   2. Rellena cada valor con los datos de tu cuenta en emailjs.com
#   3. El archivo ".env" NUNCA debe subirse a GitHub (ya está en .gitignore)
# ============================================================

# Tu Service ID de EmailJS (ya lo tienes)
VITE_EMAILJS_SERVICE_ID=service_wosq0pz

# Template ID del correo de CONFIRMACIÓN DE PEDIDO (nuevo)
VITE_EMAILJS_TEMPLATE_PEDIDO=template_dg25ot9

# Tu Public Key de EmailJS (Account → API Keys → Public Key)
VITE_EMAILJS_PUBLIC_KEY=zihjGl-LfG0EFZnhv
