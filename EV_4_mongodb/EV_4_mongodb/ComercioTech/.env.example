# ================================================================
#  .env.example — Plantilla de variables de entorno
#  ComercioTech · Python + PyMongo
#
#  INSTRUCCIONES:
#  1. Copiar este archivo: copy .env.example .env
#  2. Ajustar MONGO_URI si tu MongoDB usa credenciales
#  3. NUNCA subir .env a Git
# ================================================================

# ─── URI de conexión MongoDB ────────────────────────────────────
# Sin autenticación (desarrollo local):
MONGO_URI=mongodb://localhost:27017/

# Con autenticación (producción):
# MONGO_URI=mongodb://usuario:password@localhost:27017/

# ─── Base de datos ──────────────────────────────────────────────
MONGO_DB=comerciotech

# ─── Pool de conexiones ─────────────────────────────────────────
MONGO_MAX_POOL_SIZE=10
MONGO_MIN_POOL_SIZE=2
MONGO_CONNECT_TIMEOUT_MS=3000
MONGO_SERVER_SELECTION_TIMEOUT_MS=5000
